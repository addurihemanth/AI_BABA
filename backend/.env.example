###############################################################
# AI_BABA
# Environment Configuration Template
###############################################################

###############################################################
# APPLICATION
###############################################################

APP_NAME=AI_BABA
APP_VERSION=1.0.0
APP_DESCRIPTION=Enterprise AI Platform

DEBUG=True

HOST=0.0.0.0
PORT=8000

API_PREFIX=/api/v1

###############################################################
# SECURITY
###############################################################

SECRET_KEY=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_SECRET

ALGORITHM=HS256

ACCESS_TOKEN_EXPIRE_MINUTES=60

###############################################################
# DATABASE
###############################################################

DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_NAME=ai_baba

DATABASE_USER=postgres
DATABASE_PASSWORD=YOUR_POSTGRES_PASSWORD

DATABASE_URL=postgresql+psycopg://postgres:YOUR_POSTGRES_PASSWORD@localhost:5432/ai_baba

DATABASE_ECHO=False

###############################################################
# REDIS
###############################################################

REDIS_HOST=localhost
REDIS_PORT=6379

REDIS_URL=redis://localhost:6379/0

###############################################################
# CELERY
###############################################################

CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0

###############################################################
# OPENAI
###############################################################

OPENAI_API_KEY=

###############################################################
# GOOGLE GEMINI
###############################################################

GEMINI_API_KEY=

###############################################################
# ANTHROPIC CLAUDE
###############################################################

ANTHROPIC_API_KEY=

###############################################################
# GROK
###############################################################

GROK_API_KEY=

###############################################################
# DEEPSEEK
###############################################################

DEEPSEEK_API_KEY=

###############################################################
# LOGGING
###############################################################

LOG_LEVEL=INFO
LOG_FILE=logs/ai_baba.log

###############################################################
# CORS
###############################################################

CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

###############################################################
# FILE STORAGE
###############################################################

UPLOAD_DIRECTORY=uploads
MAX_UPLOAD_SIZE_MB=1024

###############################################################
# VECTOR DATABASE
###############################################################

CHROMA_DB_DIRECTORY=storage/chroma

###############################################################
# EMBEDDING MODEL
###############################################################

EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

###############################################################
# DEFAULT AI MODEL
###############################################################

DEFAULT_AI_PROVIDER=gemini

###############################################################
# FFMPEG
###############################################################

FFMPEG_BINARY=ffmpeg

###############################################################
# TIMEZONE
###############################################################

TIMEZONE=Asia/Kolkata